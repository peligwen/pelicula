# Generated by pelicula up — do not edit manually
services:
  nginx:
    ports:
      - "{{.HTTPPort}}:80"
      - "{{.HTTPSPort}}:8443"
{{if .LetsEncrypt}}
  certbot:
    image: certbot/certbot:latest
    pid: "service:nginx"
    volumes:
      - {{.LEStateDir}}:/etc/letsencrypt
      - {{.CertDir}}:/out
      - {{.AcmeDir}}:/var/www/acme
    entrypoint: /bin/sh
    command: |
      -c '
      trap exit TERM
      if [ ! -f /etc/letsencrypt/renewal/pelicula.conf ]; then
        certbot certonly {{.StagingFlag}} --webroot -w /var/www/acme \
          --agree-tos --no-eff-email -m {{.LEEmail}} \
          --cert-name pelicula -d {{.Hostname}}
        cp -L /etc/letsencrypt/live/pelicula/fullchain.pem /out/fullchain.pem
        cp -L /etc/letsencrypt/live/pelicula/privkey.pem /out/privkey.pem
        kill -HUP $(pgrep -o nginx)
      fi
      while :; do
        certbot renew {{.StagingFlag}} --webroot -w /var/www/acme \
          --deploy-hook 'cp -L /etc/letsencrypt/live/pelicula/fullchain.pem /out/fullchain.pem && cp -L /etc/letsencrypt/live/pelicula/privkey.pem /out/privkey.pem && kill -HUP $(pgrep -o nginx)'
        sleep 12h & wait $$!
      done'
    depends_on:
      - nginx
    restart: unless-stopped
{{end}}