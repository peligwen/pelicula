#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker-compose.yml"
ENV_FILE="$SCRIPT_DIR/.env"

# ── Colors ──────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

pass() { echo -e "  ${GREEN}✓${NC} $1"; }
fail() { echo -e "  ${RED}✗${NC} $1"; }
info() { echo -e "${CYAN}→${NC} $1"; }
warn() { echo -e "${YELLOW}!${NC} $1"; }

# ── Platform Detection ──────────────────────────────

PLATFORM="generic"
NEEDS_SUDO=""

detect_platform() {
    if [[ -f /proc/syno_platform ]] || [[ -d /volume1 ]]; then
        PLATFORM="synology"
    fi

    # Auto-detect whether docker needs sudo
    if ! docker info &>/dev/null; then
        if sudo docker info &>/dev/null; then
            NEEDS_SUDO="sudo"
        fi
    fi
}

detect_platform

# ── Helpers ─────────────────────────────────────────

compose_cmd() {
    $NEEDS_SUDO docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

docker_cmd() {
    $NEEDS_SUDO docker "$@"
}

load_env() {
    if [[ ! -f "$ENV_FILE" ]]; then
        echo -e "${RED}No .env file found.${NC} Run ${BOLD}./pelicula setup${NC} first."
        exit 1
    fi
    set -a
    # shellcheck source=/dev/null
    source "$ENV_FILE"
    set +a

    # Backward compat: auto-migrate old MEDIA_DIR-only .env to LIBRARY_DIR + WORK_DIR.
    # docker compose uses --env-file so both vars must be in the file itself.
    if [[ -n "${MEDIA_DIR:-}" ]] && [[ -z "${LIBRARY_DIR:-}" ]]; then
        LIBRARY_DIR="$MEDIA_DIR"
        WORK_DIR="${WORK_DIR:-$MEDIA_DIR}"
        echo "LIBRARY_DIR=\"${LIBRARY_DIR}\"" >> "$ENV_FILE"
        echo "WORK_DIR=\"${WORK_DIR}\"" >> "$ENV_FILE"
        info "Migrated MEDIA_DIR → LIBRARY_DIR and WORK_DIR in .env"
    fi
}

seed_config() {
    local file="$1" content="$2"
    if [[ ! -f "$file" ]]; then
        echo "$content" > "$file"
    fi
}

# Update or append a variable in .env (quotes value to handle spaces)
set_env_var() {
    local key="$1" value="$2"
    local tmp="${ENV_FILE}.tmp"
    grep -v "^${key}=" "$ENV_FILE" > "$tmp" 2>/dev/null || true
    echo "${key}=\"${value}\"" >> "$tmp"
    mv "$tmp" "$ENV_FILE"
}

# Read a variable directly from .env (not from the current environment)
get_env_var() {
    local key="$1" default="${2:-}"
    local val
    val="$(grep "^${key}=" "$ENV_FILE" 2>/dev/null | cut -d'=' -f2-)"
    echo "${val:-$default}"
}

# Enforce auth bypass in *arr config.xml files even if the app overwrote the seed.
# The *arr apps rewrite config.xml on first boot with auth enabled; this patches it back.
enforce_arr_auth() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    if grep -q '<AuthenticationRequired>Enabled</AuthenticationRequired>' "$file" 2>/dev/null; then
        sed -i.bak \
            -e 's|<AuthenticationMethod>[^<]*</AuthenticationMethod>|<AuthenticationMethod>External</AuthenticationMethod>|' \
            -e 's|<AuthenticationRequired>[^<]*</AuthenticationRequired>|<AuthenticationRequired>DisabledForLocalAddresses</AuthenticationRequired>|' \
            "$file" && rm -f "${file}.bak"
    fi
}

prompt() {
    local var_name="$1" prompt_text="$2" default="${3:-}"
    if [[ -n "$default" ]]; then
        echo -en "${BOLD}${prompt_text}${NC} [${default}]: "
        read -r value
        printf -v "$var_name" '%s' "${value:-$default}"
    else
        echo -en "${BOLD}${prompt_text}${NC}: "
        read -r value
        while [[ -z "$value" ]]; do
            echo -en "  ${RED}Required.${NC} ${prompt_text}: "
            read -r value
        done
        printf -v "$var_name" '%s' "$value"
    fi
}

# ── Commands ────────────────────────────────────────

cmd_setup() {
    local advanced=0
    [[ "${1:-}" == "--advanced" ]] && advanced=1

    echo -e "${BOLD}pelicula setup${NC}"
    [[ $advanced -eq 1 ]] && echo -e "  ${CYAN}Advanced mode${NC}"
    echo ""

    # Platform defaults
    local default_config default_media
    if [[ "$PLATFORM" == "synology" ]]; then
        info "Detected platform: ${BOLD}Synology NAS${NC}"
        default_config="/volume1/docker/media-stack/config"
        default_media="/volume1/media"
    else
        local os_label="Linux"
        [[ "$(uname)" == "Darwin" ]] && os_label="macOS"
        [[ -n "${WSL_DISTRO_NAME:-}" ]] && os_label="WSL ($WSL_DISTRO_NAME)"
        info "Detected platform: ${BOLD}${os_label}${NC}"
        default_config="$SCRIPT_DIR/config"
        default_media="$HOME/media"
    fi
    echo ""

    # ── Required: WireGuard key ──────────────────────
    echo -e "${CYAN}You need a Wireguard private key from ProtonVPN.${NC}"
    echo "  1. Log in at https://account.proton.me"
    echo "  2. Downloads → WireGuard configuration"
    echo "  3. Platform: GNU/Linux, enable NAT-PMP (Port Forwarding)"
    echo "  4. Do NOT enable Moderate NAT"
    echo "  5. Copy the PrivateKey value"
    echo ""
    prompt WIREGUARD_PRIVATE_KEY "Wireguard private key"

    if [[ ${#WIREGUARD_PRIVATE_KEY} -ne 44 ]] || [[ "${WIREGUARD_PRIVATE_KEY: -1}" != "=" ]]; then
        warn "Key doesn't look like a standard Wireguard key (expected 44 chars ending in =)"
        echo -en "  Continue anyway? [y/N]: "
        read -r confirm
        if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
            echo "Aborted."
            exit 1
        fi
    fi
    echo ""

    # ── Required: VPN country ────────────────────────
    echo "P2P-friendly countries: Netherlands, Switzerland, Sweden, Iceland, Romania"
    prompt SERVER_COUNTRIES "VPN server country" "Netherlands"
    echo ""

    # ── Auto-detected in basic mode; prompted in advanced ──
    local detected_tz=""
    if [[ -L /etc/localtime ]]; then
        detected_tz="$(readlink /etc/localtime | sed 's|.*/zoneinfo/||')"
    elif [[ -f /etc/timezone ]]; then
        detected_tz="$(cat /etc/timezone)"
    fi

    if [[ $advanced -eq 1 ]]; then
        prompt TZ "Timezone" "${detected_tz:-America/New_York}"
        echo ""
        prompt PUID "User ID (PUID)" "$(id -u)"
        prompt PGID "Group ID (PGID)" "$(id -g)"
        echo ""
        prompt CONFIG_DIR "Config directory" "$default_config"
        echo ""
        echo "  Library dir — where movies/ and tv/ are stored (can be a NAS mount)"
        prompt LIBRARY_DIR "Library directory" "$default_media"
        echo "  Work dir — where downloads/ and processing/ live (local to this stack)"
        prompt WORK_DIR "Work directory" "$default_media"
        echo ""
        prompt PELICULA_PORT "Dashboard port" "7354"
        echo ""

        # Auth setup
        echo -e "${BOLD}Auth${NC}"
        echo "  1) Off — no auth required (single-user LAN)"
        echo "  2) Password — single shared password"
        echo ""
        echo -en "Auth mode [1-2, default 1]: "
        read -r auth_choice
        local PELICULA_AUTH="off"
        local PELICULA_PASSWORD=""
        if [[ "$auth_choice" == "2" ]]; then
            echo -en "${BOLD}Password${NC}: "
            read -rs PELICULA_PASSWORD
            echo ""
            if [[ -z "$PELICULA_PASSWORD" ]]; then
                warn "Empty password — auth disabled"
            else
                PELICULA_AUTH="true"
            fi
        fi
        echo ""
    else
        TZ="${detected_tz:-America/New_York}"
        PUID="$(id -u)"
        PGID="$(id -g)"
        CONFIG_DIR="$default_config"
        LIBRARY_DIR="$default_media"
        WORK_DIR="$default_media"
        PELICULA_PORT="7354"
        PELICULA_AUTH="off"
        PELICULA_PASSWORD=""
        info "Using defaults: TZ=${TZ}, PUID=${PUID}, config=${CONFIG_DIR}"
        echo ""
    fi

    # Expand ~ in paths
    CONFIG_DIR="${CONFIG_DIR/#\~/$HOME}"
    LIBRARY_DIR="${LIBRARY_DIR/#\~/$HOME}"
    WORK_DIR="${WORK_DIR/#\~/$HOME}"

    # Write .env — quote values so paths with spaces survive `source`
    cat > "$ENV_FILE" <<EOF
# Generated by ./pelicula setup
CONFIG_DIR="${CONFIG_DIR}"
LIBRARY_DIR="${LIBRARY_DIR}"
WORK_DIR="${WORK_DIR}"
PUID="${PUID}"
PGID="${PGID}"
TZ="${TZ}"
WIREGUARD_PRIVATE_KEY="${WIREGUARD_PRIVATE_KEY}"
SERVER_COUNTRIES="${SERVER_COUNTRIES}"
PELICULA_PORT="${PELICULA_PORT}"
PELICULA_AUTH="${PELICULA_AUTH}"
PELICULA_PASSWORD="${PELICULA_PASSWORD}"
JELLYSEERR_ENABLED=false
TRANSCODING_ENABLED=false
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_MODE=internal
EOF
    chmod 600 "$ENV_FILE"
    pass "Wrote ${ENV_FILE}"

    setup_dirs "$CONFIG_DIR" "$LIBRARY_DIR" "$WORK_DIR"
    setup_cert "$CONFIG_DIR"
    setup_tun
    echo ""
    echo -e "${GREEN}${BOLD}Setup complete!${NC}"
    if [[ $advanced -eq 0 ]]; then
        echo -e "Run ${BOLD}./pelicula configure${NC} to set up auth, notifications, and more."
    fi
    echo -e "Run ${BOLD}./pelicula up${NC} to start the stack."
}

# Create required directory structure
# Usage: setup_dirs <config_dir> <library_dir> <work_dir>
setup_dirs() {
    local config_dir="$1" library_dir="$2" work_dir="$3"
    mkdir -p \
        "$config_dir/gluetun" \
        "$config_dir/qbittorrent" \
        "$config_dir/prowlarr" \
        "$config_dir/sonarr" \
        "$config_dir/radarr" \
        "$config_dir/jellyfin" \
        "$config_dir/procula/jobs" \
        "$config_dir/procula/profiles" \
        "$config_dir/pelicula" \
        "$config_dir/certs" \
        "$library_dir/movies" \
        "$library_dir/tv" \
        "$work_dir/downloads" \
        "$work_dir/processing"
    pass "Created directory structure"
}

# Generate self-signed TLS cert if not present
setup_cert() {
    local config_dir="$1"
    if [[ ! -f "$config_dir/certs/pelicula.crt" ]]; then
        openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
            -keyout "$config_dir/certs/pelicula.key" \
            -out "$config_dir/certs/pelicula.crt" \
            -subj "/CN=pelicula" \
            -addext "subjectAltName=DNS:localhost,IP:127.0.0.1" \
            2>/dev/null
        pass "Generated self-signed TLS certificate (valid 10 years)"
    else
        pass "TLS certificate exists"
    fi
}

# Check and create /dev/net/tun on Linux (macOS uses utun via Docker Desktop)
setup_tun() {
    if [[ "$(uname)" == "Darwin" ]]; then
        return 0
    fi

    if [[ ! -c /dev/net/tun ]]; then
        warn "/dev/net/tun not found (required for VPN)"
        echo -en "  Create it now with sudo? [Y/n]: "
        read -r confirm
        if [[ "$confirm" != "n" && "$confirm" != "N" ]]; then
            sudo mkdir -p /dev/net
            sudo mknod /dev/net/tun c 10 200
            sudo chmod 600 /dev/net/tun
            pass "Created /dev/net/tun"
            if [[ "$PLATFORM" == "synology" ]]; then
                warn "Add a boot-up task in DSM to recreate this on reboot:"
                echo "    Control Panel → Task Scheduler → Triggered Task (Boot-up, root)"
                echo "    Script: mkdir -p /dev/net && mknod /dev/net/tun c 10 200 && chmod 600 /dev/net/tun"
            else
                warn "This device node may not persist across reboots on some systems"
            fi
        fi
    else
        pass "/dev/net/tun exists"
    fi

    cat > "$SCRIPT_DIR/docker-compose.override.yml" <<'OVERRIDE'
services:
  gluetun:
    devices:
      - /dev/net/tun:/dev/net/tun
OVERRIDE
    pass "Wrote docker-compose.override.yml (TUN device mapping)"
}

# ── Configure ────────────────────────────────────────

cmd_configure() {
    load_env

    while true; do
        echo ""
        echo -e "${BOLD}Pelicula Configuration${NC}"
        echo ""

        local auth_mode notifications transcoding jellyseerr port vpn_country
        auth_mode="$(get_env_var PELICULA_AUTH off)"
        [[ "$auth_mode" == "true" ]] && auth_mode="password"
        notifications="$(get_env_var NOTIFICATIONS_MODE internal)"
        transcoding="$(get_env_var TRANSCODING_ENABLED false)"
        jellyseerr="$(get_env_var JELLYSEERR_ENABLED false)"
        port="$(get_env_var PELICULA_PORT 7354)"
        vpn_country="$(get_env_var SERVER_COUNTRIES Netherlands)"

        local transcode_label jellyseerr_label
        [[ "$transcoding" == "true" ]] && transcode_label="enabled" || transcode_label="off"
        [[ "$jellyseerr" == "true" ]] && jellyseerr_label="enabled" || jellyseerr_label="off"

        echo "  1) Auth          mode: ${auth_mode}"
        echo "  2) Notifications mode: ${notifications}"
        echo "  3) Transcoding   ${transcode_label}"
        echo "  4) Jellyseerr    ${jellyseerr_label}"
        echo "  5) Network       port ${port}, ${vpn_country}"
        echo "  6) Paths"
        echo "  7) VPN Key"
        echo "  q) Quit"
        echo ""
        echo -en "Select [1-7, q]: "
        read -r choice
        case "$choice" in
            1) configure_auth ;;
            2) configure_notifications ;;
            3) configure_transcoding ;;
            4) configure_jellyseerr ;;
            5) configure_network ;;
            6) configure_paths ;;
            7) configure_vpn_key ;;
            q|Q) echo ""; break ;;
            *) warn "Unknown option" ;;
        esac
    done
}

configure_auth() {
    echo ""
    echo -e "${BOLD}Auth${NC}"
    echo ""
    local current
    current="$(get_env_var PELICULA_AUTH off)"
    [[ "$current" == "true" ]] && current="password"
    echo "  Current mode: ${current}"
    echo ""
    echo "  1) off      — no auth required (single-user LAN)"
    echo "  2) password — single shared password (admin only)"
    echo "  3) users    — multi-user with roles (viewer / manager / admin)"
    echo ""
    echo -en "Select [1-3]: "
    read -r choice
    case "$choice" in
        1)
            set_env_var PELICULA_AUTH off
            set_env_var PELICULA_PASSWORD ""
            pass "Auth disabled"
            warn "Restart services: ./pelicula restart"
            ;;
        2)
            echo -en "${BOLD}Password${NC}: "
            read -rs pw
            echo ""
            if [[ -z "$pw" ]]; then
                warn "Password cannot be empty — no changes made"
                return
            fi
            set_env_var PELICULA_AUTH true
            set_env_var PELICULA_PASSWORD "$pw"
            pass "Password auth configured"
            warn "Restart services: ./pelicula restart"
            ;;
        3)
            set_env_var PELICULA_AUTH users
            set_env_var PELICULA_PASSWORD ""
            pass "Auth mode set to users"
            configure_users
            ;;
        *)
            warn "Unknown option"
            ;;
    esac
}

# Hash a password using salted SHA-256: "sha256v2:SALT:hex(sha256(salt:username:password))"
# Falls back to legacy unsalted format if openssl rand is unavailable.
hash_password() {
    local username="$1" password="$2"
    local salt
    salt="$(openssl rand -hex 16 2>/dev/null)"
    if [[ -n "$salt" ]]; then
        local hash
        hash="$(printf '%s:%s:%s' "$salt" "$username" "$password" | openssl dgst -sha256 -hex 2>/dev/null | awk '{print $NF}')"
        printf 'sha256v2:%s:%s' "$salt" "$hash"
    else
        # Legacy fallback (no salt) — older openssl without rand subcommand
        printf '%s:%s' "$username" "$password" | openssl dgst -sha256 -hex 2>/dev/null | awk '{print $NF}'
    fi
}

configure_users() {
    load_env
    local users_file="${CONFIG_DIR}/pelicula/users.json"
    mkdir -p "$(dirname "$users_file")"

    # Initialize empty array if file doesn't exist
    [[ ! -f "$users_file" ]] && echo '[]' > "$users_file"

    while true; do
        echo ""
        echo -e "${BOLD}User Management${NC}"
        echo ""

        # List current users
        if command -v python3 &>/dev/null; then
            USERS_FILE="$users_file" python3 -c "
import json, os, sys
try:
    users = json.load(open(os.environ['USERS_FILE']))
    if not users:
        print('  (no users)')
    for u in users:
        print(f\"  {u['username']:20s} {u.get('role','?')}\")
except: print('  (could not read users file)')
"
        else
            info "Users file: ${users_file}"
        fi

        echo ""
        echo "  1) Add user"
        echo "  2) Remove user"
        echo "  3) Change password"
        echo "  4) Change role"
        echo "  b) Back"
        echo ""
        echo -en "Select [1-4, b]: "
        read -r choice
        case "$choice" in
            1) add_user "$users_file" ;;
            2) remove_user "$users_file" ;;
            3) change_user_password "$users_file" ;;
            4) change_user_role "$users_file" ;;
            b|B) break ;;
            *) warn "Unknown option" ;;
        esac
    done
    warn "Restart pelicula-api for user changes to take effect: ./pelicula restart-acquire"
}

add_user() {
    local users_file="$1"
    echo ""
    prompt username "Username"
    echo -en "${BOLD}Password${NC}: "
    read -rs pw
    echo ""
    if [[ -z "$pw" ]]; then warn "Password cannot be empty"; return; fi
    echo ""
    echo "  Roles:"
    echo "    viewer  — read-only dashboard, can request via Jellyseerr"
    echo "    manager — search + add content, pause/resume downloads"
    echo "    admin   — full access including cancel and blocklist"
    echo ""
    echo -en "Role [viewer/manager/admin, default admin]: "
    read -r role
    case "$role" in
        viewer|manager|admin) ;;
        "") role="admin" ;;
        *) warn "Invalid role — must be viewer, manager, or admin"; return ;;
    esac
    local hash
    hash="$(hash_password "$username" "$pw")"
    if [[ -z "$hash" ]]; then
        warn "Could not hash password (openssl required)"
        return
    fi
    # Append user to JSON array using python3 if available, otherwise manual
    if command -v python3 &>/dev/null; then
        USERS_FILE="$users_file" USERNAME="$username" HASH="$hash" ROLE="$role" python3 -c "
import json, os
e = os.environ
users = json.load(open(e['USERS_FILE']))
users = [u for u in users if u['username'] != e['USERNAME']]
users.append({'username': e['USERNAME'], 'password': e['HASH'], 'role': e['ROLE']})
json.dump(users, open(e['USERS_FILE'], 'w'), indent=2)
print('ok')
" | grep -q ok && pass "User '${username}' added (${role})" || warn "Failed to write users file"
    else
        warn "python3 not found — cannot update users.json automatically"
        info "Manually add to ${users_file}:"
        echo "  {\"username\": \"${username}\", \"password\": \"${hash}\", \"role\": \"${role}\"}"
    fi
}

remove_user() {
    local users_file="$1"
    echo ""
    prompt username "Username to remove"
    if command -v python3 &>/dev/null; then
        USERS_FILE="$users_file" USERNAME="$username" python3 -c "
import json, os
e = os.environ
users = json.load(open(e['USERS_FILE']))
before = len(users)
users = [u for u in users if u['username'] != e['USERNAME']]
json.dump(users, open(e['USERS_FILE'], 'w'), indent=2)
print('removed' if len(users) < before else 'notfound')
" | grep -q removed && pass "User '${username}' removed" || warn "User '${username}' not found"
    else
        warn "python3 not found — edit ${users_file} manually"
    fi
}

change_user_password() {
    local users_file="$1"
    echo ""
    prompt username "Username"
    echo -en "${BOLD}New password${NC}: "
    read -rs pw
    echo ""
    if [[ -z "$pw" ]]; then warn "Password cannot be empty"; return; fi
    local hash
    hash="$(hash_password "$username" "$pw")"
    if command -v python3 &>/dev/null; then
        USERS_FILE="$users_file" USERNAME="$username" HASH="$hash" python3 -c "
import json, os
e = os.environ
users = json.load(open(e['USERS_FILE']))
found = False
for u in users:
    if u['username'] == e['USERNAME']:
        u['password'] = e['HASH']; found = True
json.dump(users, open(e['USERS_FILE'], 'w'), indent=2)
print('ok' if found else 'notfound')
" | grep -q ok && pass "Password updated for '${username}'" || warn "User '${username}' not found"
    else
        warn "python3 not found — edit ${users_file} manually"
    fi
}

change_user_role() {
    local users_file="$1"
    echo ""
    prompt username "Username"
    echo -en "New role [viewer/manager/admin]: "
    read -r role
    case "$role" in
        viewer|manager|admin) ;;
        *) warn "Invalid role"; return ;;
    esac
    if command -v python3 &>/dev/null; then
        USERS_FILE="$users_file" USERNAME="$username" ROLE="$role" python3 -c "
import json, os
e = os.environ
users = json.load(open(e['USERS_FILE']))
found = False
for u in users:
    if u['username'] == e['USERNAME']:
        u['role'] = e['ROLE']; found = True
json.dump(users, open(e['USERS_FILE'], 'w'), indent=2)
print('ok' if found else 'notfound')
" | grep -q ok && pass "Role for '${username}' set to ${role}" || warn "User '${username}' not found"
    else
        warn "python3 not found — edit ${users_file} manually"
    fi
}

configure_notifications() {
    echo ""
    echo -e "${BOLD}Notifications${NC}"
    echo ""
    local mode
    mode="$(get_env_var NOTIFICATIONS_MODE internal)"
    echo "  Current mode: ${mode}"
    echo ""
    echo "  The in-dashboard bell feed is always on (zero config)."
    echo "  Choose an external provider to also push to your phone, email, etc."
    echo ""
    echo "  1) Internal only  — dashboard bell, no external service"
    echo "  2) Apprise        — ntfy, Gotify, email/SMTP, Pushover, Telegram, and 85+ others"
    echo "  3) Direct webhook — HTTP POST to any URL (ntfy, Gotify, custom receiver)"
    echo "  b) Back"
    echo ""
    echo -en "Select [1-3, b]: "
    read -r choice
    case "$choice" in
        1)
            set_env_var NOTIFICATIONS_MODE internal
            set_env_var NOTIFICATIONS_ENABLED false
            pass "External notifications disabled (dashboard feed still active)"
            ;;
        2)
            setup_apprise_notifications
            ;;
        3)
            setup_direct_notifications
            ;;
        b|B) return ;;
        *)
            warn "Unknown option"
            ;;
    esac
}

setup_apprise_notifications() {
    echo ""
    echo "  Apprise URLs — one provider URL per line (empty line to finish)."
    echo "  Examples:"
    echo "    ntfy://my-server.com/my-topic"
    echo "    gotify://hostname/AppToken"
    echo "    mailto://user:pass@gmail.com"
    echo ""
    local notif_cfg
    notif_cfg="${CONFIG_DIR}/procula/notifications.json"
    local line
    local urls_collected=()
    while true; do
        echo -en "  URL (or Enter to finish): "
        read -r line
        [[ -z "$line" ]] && break
        urls_collected+=("$line")
    done
    # JSON-encode the URL array via python3 to handle special characters safely
    local urls_json="[]"
    if [[ ${#urls_collected[@]} -gt 0 ]]; then
        urls_json="$(printf '%s\n' "${urls_collected[@]}" | python3 -c "import json,sys; print(json.dumps([l.rstrip() for l in sys.stdin]))" 2>/dev/null || echo '[]')"
    fi
    mkdir -p "$(dirname "$notif_cfg")"
    cat > "$notif_cfg" <<EOF
{
  "mode": "apprise",
  "apprise_urls": ${urls_json},
  "direct_url": ""
}
EOF
    set_env_var NOTIFICATIONS_MODE apprise
    set_env_var NOTIFICATIONS_ENABLED true
    pass "Apprise notifications configured"
