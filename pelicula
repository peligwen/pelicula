# Services that can be restarted without affecting playback.
# Order matters: gluetun must come up before qbittorrent (network_mode dependency).
ACQUIRE_SERVICES="gluetun qbittorrent prowlarr sonarr radarr pelicula-api procula"

cmd_restart_acquire() {
    load_env
    info "Restarting acquisition services (jellyfin and nginx stay up)..."
    # shellcheck disable=SC2086
    compose_cmd stop $ACQUIRE_SERVICES
    # shellcheck disable=SC2086
    compose_cmd start $ACQUIRE_SERVICES
    # *arr apps rewrite config.xml on startup with auth enabled; patch it back.
    enforce_arr_auth "$CONFIG_DIR/sonarr/config.xml"
    enforce_arr_auth "$CONFIG_DIR/radarr/config.xml"
    enforce_arr_auth "$CONFIG_DIR/prowlarr/config.xml"
    pass "Acquisition services restarted"
}

