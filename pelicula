    code="$(echo "$resp" | tail -1)"
    body="$(echo "$resp" | head -n -1)"

    if [[ "$code" == "000" ]] || [[ -z "$code" ]]; then
        fail "Could not reach pelicula-api at http://localhost:${port} — is the stack running?"
        exit 1
    fi
    if [[ "$code" != "200" ]]; then
        fail "Export failed (HTTP $code): $body"
        exit 1
    fi

    if ! echo "$body" | python3 -c "import sys,json; json.load(sys.stdin)" 2>/dev/null; then
