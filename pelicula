_remote_set_cert_mode() {
    echo ""
    local current
    current="$(get_env_var REMOTE_CERT_MODE self-signed)"
    echo "  Current: ${current}"
    echo ""
    echo "  1) Let's Encrypt  — automatic cert via HTTP-01 (requires port 80 reachable)"
    echo "  2) BYO cert       — drop fullchain.pem + privkey.pem into config/certs/remote/"
    echo "  3) Self-signed    — auto-generated; browsers will warn (direct-IP / testing only)"
    echo ""
    echo -en "Select [1-3]: "
    read -r choice
    case "$choice" in
        1)
            local le_email
            le_email="$(get_env_var REMOTE_LE_EMAIL "")"
            if [[ -z "$le_email" ]]; then
                echo ""
                echo "  Let's Encrypt needs an email for expiry notices and account recovery."
                prompt le_email "Email address"
            fi
            echo ""
            echo -en "  Use Let's Encrypt staging CA? (use this for testing to avoid rate limits) [y/N]: "
            read -r staging
            local le_staging="false"
            [[ "$staging" == "y" || "$staging" == "Y" ]] && le_staging="true"
            set_env_var REMOTE_CERT_MODE letsencrypt
            set_env_var REMOTE_LE_EMAIL "$le_email"
            set_env_var REMOTE_LE_STAGING "$le_staging"
            pass "Cert mode: Let's Encrypt (staging: ${le_staging})"
            echo ""
            echo "  A certbot sidecar will issue and auto-renew the cert on ./pelicula up."
            echo "  Ensure port $(get_env_var REMOTE_HTTP_PORT 80) is forwarded from your router."
            ;;
        2)
            local config_dir
            config_dir="$(get_env_var CONFIG_DIR ./config)"
            set_env_var REMOTE_CERT_MODE byo
            pass "Cert mode: BYO"
            echo ""
            echo "  Place your certificate files at:"
            echo "    ${config_dir}/certs/remote/fullchain.pem"
            echo "    ${config_dir}/certs/remote/privkey.pem"
            echo "  Then run: ./pelicula up"
            ;;
        3)
            set_env_var REMOTE_CERT_MODE self-signed
            echo ""
            echo -e "  ${YELLOW}Warning:${NC} self-signed certs cause browser security warnings and are"
            echo "  rejected by most Jellyfin mobile and TV apps. Suitable for testing only."
            pass "Cert mode: self-signed"
            ;;
        *)
            warn "Unknown option"
            ;;
    esac
    warn "Run ./pelicula up to apply"
}

# Render nginx/remote.conf and docker-compose.remote.yml from current .env.
# Called by cmd_up before starting the stack.
render_remote_configs() {
    local remote_enabled
    remote_enabled="$(get_env_var REMOTE_ACCESS_ENABLED false)"

    local remote_conf="${SCRIPT_DIR}/nginx/remote.conf"
    local remote_compose="${SCRIPT_DIR}/docker-compose.remote.yml"
    local cert_dir="${CONFIG_DIR}/certs/remote"
    local acme_dir="${CONFIG_DIR}/certs/acme-webroot"

    if [[ "$remote_enabled" != "true" ]]; then
        # Write empty file so nginx include doesn't error
        echo "# Remote access disabled" > "$remote_conf"
        rm -f "$remote_compose"
        return 0
    fi

    local hostname https_port http_port cert_mode le_email le_staging
    hostname="$(get_env_var REMOTE_HOSTNAME "")"
    https_port="$(get_env_var REMOTE_HTTPS_PORT 8920)"
    http_port="$(get_env_var REMOTE_HTTP_PORT 80)"
    cert_mode="$(get_env_var REMOTE_CERT_MODE self-signed)"
    le_email="$(get_env_var REMOTE_LE_EMAIL "")"
    le_staging="$(get_env_var REMOTE_LE_STAGING false)"

    if [[ -z "$hostname" ]]; then
        echo -e "${RED}Error:${NC} REMOTE_ACCESS_ENABLED=true but REMOTE_HOSTNAME is not set."
        echo -e "Run ${BOLD}./pelicula configure${NC} → Remote access to set a hostname."
        exit 1
    fi

    # Create cert and ACME dirs
    mkdir -p "$cert_dir" "$acme_dir"

    # Provision cert based on mode
    case "$cert_mode" in
        self-signed)
            _remote_ensure_selfsigned_cert "$cert_dir" "$hostname"
            ;;
        byo)
            if [[ ! -f "$cert_dir/fullchain.pem" ]] || [[ ! -f "$cert_dir/privkey.pem" ]]; then
                echo -e "${RED}Error:${NC} BYO cert mode requires certificate files:"
                echo "  ${cert_dir}/fullchain.pem"
                echo "  ${cert_dir}/privkey.pem"
                echo "Place your certificate there and re-run ./pelicula up"
                exit 1
            fi
            pass "BYO certificate found"
            ;;
        letsencrypt)
            # nginx needs a cert on disk to start; bootstrap with self-signed if absent.
            # Certbot will replace it on first successful renewal.
            if [[ ! -f "$cert_dir/fullchain.pem" ]] || [[ ! -f "$cert_dir/privkey.pem" ]]; then
                info "No cert yet — generating bootstrap self-signed for nginx startup"
                _remote_ensure_selfsigned_cert "$cert_dir" "$hostname"
                warn "Certbot will replace this with a real Let's Encrypt cert on first run"
            else
                pass "Certificate found ($(openssl x509 -noout -issuer -in "$cert_dir/fullchain.pem" 2>/dev/null | sed 's/.*CN *= *//' || echo unknown))"
            fi
            ;;
    esac

    # Render nginx/remote.conf from template via envsubst
    if [[ ! -f "${SCRIPT_DIR}/nginx/remote.conf.template" ]]; then
        echo -e "${RED}Error:${NC} nginx/remote.conf.template not found"
        exit 1
    fi
    REMOTE_HOSTNAME="$hostname" REMOTE_HTTPS_PORT="$https_port" \
        envsubst '${REMOTE_HOSTNAME} ${REMOTE_HTTPS_PORT}' \
        < "${SCRIPT_DIR}/nginx/remote.conf.template" > "$remote_conf"
    pass "Rendered nginx remote vhost (${hostname}:${https_port})"

    # Write docker-compose.remote.yml
    {
        echo "# Generated by ./pelicula up — do not edit manually"
        echo "services:"
        echo "  nginx:"
        echo "    ports:"
        echo "      - \"${http_port}:80\""
        echo "      - \"${https_port}:8443\""
    } > "$remote_compose"

    if [[ "$cert_mode" == "letsencrypt" ]]; then
        local staging_flag=""
        [[ "$le_staging" == "true" ]] && staging_flag="--staging "

        {
            echo ""
            echo "  certbot:"
            echo "    image: certbot/certbot:latest"
            echo "    container_name: pelicula-certbot"
            echo "    pid: \"service:nginx\""
            echo "    volumes:"
            echo "      - ${cert_dir}:/etc/letsencrypt/archive/pelicula"
            echo "      - ${CONFIG_DIR}/certs/letsencrypt:/etc/letsencrypt"
            echo "      - ${acme_dir}:/var/www/acme"
            echo "    entrypoint: /bin/sh"
            echo "    command: >-"
            echo "      -c \"trap exit TERM;"
            echo "      if [ ! -f /etc/letsencrypt/renewal/${hostname}.conf ]; then"
            echo "        certbot certonly ${staging_flag}--webroot -w /var/www/acme"
            echo "          --agree-tos --no-eff-email -m ${le_email} -d ${hostname}"
            echo "          --cert-path /etc/letsencrypt/archive/pelicula/fullchain.pem"
            echo "          --key-path /etc/letsencrypt/archive/pelicula/privkey.pem;"
            echo "      fi;"
            echo "      while :; do"
            echo "        certbot renew ${staging_flag}--webroot -w /var/www/acme"
            echo "          --deploy-hook 'nginx -s reload';"
            echo "        sleep 12h & wait \$\${!};"
            echo "      done\""
            echo "    depends_on:"
            echo "      - nginx"
            echo "    restart: unless-stopped"
        } >> "$remote_compose"
        pass "Certbot sidecar configured (${hostname}, staging: ${le_staging})"
    fi
}

# Generate a self-signed cert into the given dir for the given hostname.
_remote_ensure_selfsigned_cert() {
    local dir="$1" hostname="$2"
    if [[ -f "$dir/fullchain.pem" ]] && [[ -f "$dir/privkey.pem" ]]; then
        pass "Remote certificate exists"
        return 0
    fi
    openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
        -keyout "$dir/privkey.pem" \
        -out "$dir/fullchain.pem" \
        -subj "/CN=${hostname}" \
        -addext "subjectAltName=DNS:${hostname}" \
        2>/dev/null
    pass "Generated self-signed remote certificate (${hostname})"
}

cmd_up() {
    # If no .env, offer browser-based setup wizard
    if [[ ! -f "$ENV_FILE" ]]; then
        echo ""
        echo -e "${BOLD}No configuration found.${NC}"
        echo ""
        echo "  Option 1: Open ${BOLD}http://localhost:7354/${NC} in your browser to set up"
        echo "  Option 2: Run ${BOLD}./pelicula setup${NC} for CLI setup (Ctrl+C to abort)"
        echo ""
        info "Starting setup wizard..."

        # Detect host context to pass into the setup container
        local detected_tz=""
        if [[ -L /etc/localtime ]]; then
            detected_tz="$(readlink /etc/localtime | sed 's|.*/zoneinfo/||')"
        elif [[ -f /etc/timezone ]]; then
            detected_tz="$(cat /etc/timezone)"
        fi

        local host_platform="linux"
        if [[ "$PLATFORM" == "synology" ]]; then
            host_platform="synology"
        elif [[ "$(uname)" == "Darwin" ]]; then
            host_platform="macos"
        elif grep -qi microsoft /proc/version 2>/dev/null; then
            host_platform="wsl"
        fi

        local default_config default_library default_work
        if [[ "$host_platform" == "synology" ]]; then
            default_config="/volume1/docker/pelicula/config"
            default_library="/volume1/media"
            default_work="/volume1/media"
        else
            default_config="$SCRIPT_DIR/config"
            default_library="$HOME/media"
            default_work="$HOME/media"
        fi

        local setup_compose="$SCRIPT_DIR/docker-compose.setup.yml"

        # Clean up setup containers on Ctrl+C
        cleanup_setup() {
            echo ""
            warn "Setup aborted"
            $NEEDS_SUDO docker compose -f "$setup_compose" down 2>/dev/null
            exit 1
        }
        trap cleanup_setup INT

        HOST_PLATFORM="$host_platform" \
        HOST_TZ="${detected_tz:-America/New_York}" \
        HOST_PUID="$(id -u)" \
        HOST_PGID="$(id -g)" \
        HOST_HOME="$HOME" \
        HOST_CONFIG_DIR="$default_config" \
        HOST_LIBRARY_DIR="$default_library" \
        HOST_WORK_DIR="$default_work" \
        $NEEDS_SUDO docker compose -f "$setup_compose" up -d --build

        echo ""
        echo -e "  Open ${BOLD}http://localhost:7354/${NC} to continue setup"
        echo ""

        # Poll for .env to appear (written by the wizard), with timeout
        info "Waiting for setup to complete (Ctrl+C to abort)..."
        local wait_count=0
        while [[ ! -f "$ENV_FILE" ]]; do
            sleep 2
            wait_count=$((wait_count + 1))
            if [[ $wait_count -ge 150 ]]; then
                warn "Setup timed out after 5 minutes"
                $NEEDS_SUDO docker compose -f "$setup_compose" down 2>/dev/null
                echo -e "Run ${BOLD}./pelicula setup${NC} for CLI setup instead."
                exit 1
            fi
        done
        pass "Configuration saved"

        # Restore default signal handling
        trap - INT

        # Tear down setup containers
        $NEEDS_SUDO docker compose -f "$setup_compose" down

        echo ""
    fi

    load_env
    info "Starting media stack..."

    setup_dirs "$CONFIG_DIR" "$LIBRARY_DIR" "$WORK_DIR"
    setup_cert "$CONFIG_DIR"
    render_remote_configs

    # Verify TUN device on Linux (macOS uses utun via Docker Desktop)
    if [[ "$(uname)" != "Darwin" ]] && [[ ! -c /dev/net/tun ]]; then
        echo -e "${RED}/dev/net/tun not found.${NC} Run ${BOLD}./pelicula setup${NC} to create it."
        exit 1
    fi

    # Seed UrlBase configs for reverse proxy (first run only)
    seed_config "$CONFIG_DIR/sonarr/config.xml" \
        '<Config><UrlBase>/sonarr</UrlBase><AuthenticationMethod>External</AuthenticationMethod><AuthenticationRequired>DisabledForLocalAddresses</AuthenticationRequired></Config>'
    seed_config "$CONFIG_DIR/radarr/config.xml" \
        '<Config><UrlBase>/radarr</UrlBase><AuthenticationMethod>External</AuthenticationMethod><AuthenticationRequired>DisabledForLocalAddresses</AuthenticationRequired></Config>'
    seed_config "$CONFIG_DIR/prowlarr/config.xml" \
        '<Config><UrlBase>/prowlarr</UrlBase><AuthenticationMethod>External</AuthenticationMethod><AuthenticationRequired>DisabledForLocalAddresses</AuthenticationRequired></Config>'
    # Enforce auth bypass on existing configs (fixes *arr overwriting seed on first boot)
    enforce_arr_auth "$CONFIG_DIR/sonarr/config.xml"
    enforce_arr_auth "$CONFIG_DIR/radarr/config.xml"
    enforce_arr_auth "$CONFIG_DIR/prowlarr/config.xml"

    seed_config "$CONFIG_DIR/jellyfin/network.xml" \
        '<?xml version="1.0" encoding="utf-8"?><NetworkConfiguration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema"><BaseUrl>/jellyfin</BaseUrl></NetworkConfiguration>'
    # Seed Bazarr base_url so the UI loads correctly behind the /bazarr reverse-proxy prefix
    mkdir -p "$CONFIG_DIR/bazarr/config"
    seed_config "$CONFIG_DIR/bazarr/config/config.ini" \
'[general]
base_url=/bazarr
'
    # Seed qBittorrent config: auth bypass for Docker subnet so *arr apps can connect
    mkdir -p "$CONFIG_DIR/qbittorrent/qBittorrent"
    seed_config "$CONFIG_DIR/qbittorrent/qBittorrent/qBittorrent.conf" \
'[Preferences]
WebUI\AuthSubnetWhitelistEnabled=true
WebUI\AuthSubnetWhitelist=172.16.0.0/12
WebUI\LocalHostAuth=false
WebUI\CSRFProtection=false

[BitTorrent]
Session\DefaultSavePath=/downloads/'

    local -a profile_args=()
    [[ "$(get_env_var JELLYSEERR_ENABLED false)" == "true" ]] && profile_args+=("--profile" "jellyseerr")
    [[ "$(get_env_var NOTIFICATIONS_MODE internal)" == "apprise" ]] && profile_args+=("--profile" "apprise")

    local -a compose_extra=()
    [[ -f "${SCRIPT_DIR}/docker-compose.override.yml" ]] && compose_extra+=("-f" "${SCRIPT_DIR}/docker-compose.override.yml")
    [[ -f "${SCRIPT_DIR}/docker-compose.remote.yml" ]] && compose_extra+=("-f" "${SCRIPT_DIR}/docker-compose.remote.yml")
    $NEEDS_SUDO docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" \
        ${compose_extra[@]+"${compose_extra[@]}"} \
        ${profile_args[@]+"${profile_args[@]}"} up -d

    # Wait for gluetun health
    info "Waiting for VPN connection..."
    local attempts=0
    while [[ $attempts -lt 30 ]]; do
        local health
        health="$(docker_cmd inspect --format='{{.State.Health.Status}}' gluetun 2>/dev/null || echo "unknown")"
        if [[ "$health" == "healthy" ]]; then
            pass "Gluetun VPN connected"
            break
        fi
        sleep 2
        attempts=$((attempts + 1))
    done
    if [[ $attempts -ge 30 ]]; then
        warn "Gluetun did not become healthy within 60s. Check logs: ./pelicula logs gluetun"
    fi

    echo ""
    echo -e "${GREEN}${BOLD}Stack is running!${NC}"
    echo ""
    echo "  Service         URL"
    echo "  ─────────────── ──────────────────────────"
    local port="${PELICULA_PORT:-7354}"
    echo "  Dashboard       http://localhost:${port}/"
    echo "  Sonarr          http://localhost:${port}/sonarr/"
    echo "  Radarr          http://localhost:${port}/radarr/"
    echo "  Prowlarr        http://localhost:${port}/prowlarr/"
    echo "  qBittorrent     http://localhost:${port}/qbt/"
    echo "  Jellyfin        http://localhost:${port}/jellyfin/"
    echo "  Bazarr          http://localhost:${port}/bazarr/"
    echo "  Procula API     http://localhost:${port}/api/procula/status"
    if [[ "$(get_env_var JELLYSEERR_ENABLED false)" == "true" ]]; then
        local js_port
        js_port="$(get_env_var JELLYSEERR_PORT 5055)"
        echo "  Jellyseerr      http://localhost:${js_port}/"
    fi
    if [[ "$(get_env_var REMOTE_ACCESS_ENABLED false)" == "true" ]]; then
        local r_host r_https
        r_host="$(get_env_var REMOTE_HOSTNAME "")"
        r_https="$(get_env_var REMOTE_HTTPS_PORT 8920)"
        echo ""
        echo -e "  ${CYAN}Remote Jellyfin:${NC} https://${r_host}:${r_https}/"
        echo "  (Ensure router forwards ports $(get_env_var REMOTE_HTTP_PORT 80) and ${r_https} to this machine)"
    fi
}

cmd_down() {
