_remote_enable() {
    local hostname http_port https_port cert_mode
    hostname="$(get_env_var REMOTE_HOSTNAME "")"
    http_port="$(get_env_var REMOTE_HTTP_PORT 80)"
    https_port="$(get_env_var REMOTE_HTTPS_PORT 8920)"
    cert_mode="$(get_env_var REMOTE_CERT_MODE self-signed)"

    echo ""
    if [[ -z "$hostname" ]]; then
        echo "  Enter your public hostname (e.g. myhome.duckdns.org or jellyfin.example.com)."
        echo "  This must be a DNS name — raw IP addresses cannot get a TLS certificate."
        echo ""
        prompt hostname "Public hostname"
        # Strip any scheme or trailing slashes the user might paste
        hostname="${hostname#http://}"
        hostname="${hostname#https://}"
        hostname="${hostname%%/*}"
        if [[ -z "$hostname" ]]; then
            warn "Hostname is required — no changes made"
            return
        fi
        set_env_var REMOTE_HOSTNAME "$hostname"
    fi

    set_env_var REMOTE_ACCESS_ENABLED true
    set_env_var REMOTE_HTTP_PORT "$http_port"
    set_env_var REMOTE_HTTPS_PORT "$https_port"
    set_env_var REMOTE_CERT_MODE "$cert_mode"

    pass "Remote access enabled"
    echo ""
    echo -e "  ${CYAN}Router port forwards required:${NC}"
    echo "    External port ${http_port}  → this machine port ${http_port}   (HTTP redirect + ACME renewal)"
    echo "    External port ${https_port} → this machine port ${https_port}  (Jellyfin HTTPS)"
    echo ""
    if [[ "$cert_mode" == "letsencrypt" ]]; then
        echo -e "  ${CYAN}Let's Encrypt:${NC} port ${http_port} must be reachable from the internet for"
        echo "  automatic certificate issuance and renewal."
    elif [[ "$cert_mode" == "byo" ]]; then
        echo -e "  ${CYAN}BYO cert:${NC} place your certificate at:"
        echo "    $(get_env_var CONFIG_DIR)/certs/remote/fullchain.pem"
        echo "    $(get_env_var CONFIG_DIR)/certs/remote/privkey.pem"
    elif [[ "$cert_mode" == "self-signed" ]]; then
        echo -e "  ${YELLOW}Self-signed cert:${NC} browsers and Jellyfin mobile apps will show security"
        echo "  warnings. Use Let's Encrypt for real remote access."
    fi
    echo ""
    warn "Run ./pelicula up to apply"
}

_remote_disable() {
    set_env_var REMOTE_ACCESS_ENABLED false
    pass "Remote access disabled"
    warn "Run ./pelicula up to apply"
}

_remote_set_hostname() {
    echo ""
    local current
    current="$(get_env_var REMOTE_HOSTNAME "")"
    [[ -n "$current" ]] && echo "  Current: ${current}"
    echo ""
    prompt new_hostname "Public hostname (e.g. myhome.duckdns.org)"
