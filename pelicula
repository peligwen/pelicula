    fi
    local port="${PELICULA_PORT:-7354}"
    local date
    date="$(date +%Y-%m-%d)"
    local outfile="${1:-pelicula-backup-${date}.json}"

    info "Exporting library metadata..."
    local resp
    resp="$(curl -s --max-time 60 -w "\n%{http_code}" "http://localhost:${port}/api/pelicula/export" 2>/dev/null)"
