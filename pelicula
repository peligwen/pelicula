cmd_rebuild() {
    load_env

    local -a targets=("$@")
    if [[ ${#targets[@]} -eq 0 ]]; then
        targets=("pelicula-api" "procula")
    fi

    for svc in "${targets[@]}"; do
        case "$svc" in
            nginx)
                info "Reloading nginx..."
                docker_cmd exec nginx nginx -s reload
                pass "nginx reloaded"
                ;;
            pelicula-api|middleware)
                info "Rebuilding pelicula-api..."
                compose_cmd build pelicula-api
                compose_cmd up -d --no-deps pelicula-api
                pass "pelicula-api rebuilt and restarted"
                ;;
            procula)
                info "Rebuilding procula..."
                compose_cmd build procula
                compose_cmd up -d --no-deps procula
                pass "procula rebuilt and restarted"
                ;;
            *)
                warn "Unknown service '${svc}'. Known targets: pelicula-api, procula, nginx"
                ;;
        esac
    done
}

cmd_check_vpn() {
    load_env
    local port="${PELICULA_PORT:-7354}"

    echo -e "${BOLD}VPN & Service Health Check${NC}"
    echo ""

    local resp
    resp="$(curl -s --max-time 10 "http://localhost:${port}/api/pelicula/health" 2>/dev/null)"
    if [[ -z "$resp" ]]; then
        fail "Could not reach middleware at http://localhost:${port} — is the stack running?"
        echo ""
        info "Run: ./pelicula up"
        exit 1
    fi

    # Parse JSON with python3 (already required for user management).
    # Pass the response via env var to avoid bash quoting/escaping issues.
    HEALTH_JSON="$resp" python3 - <<'PYEOF'
import json, os, sys

try:
    data = json.loads(os.environ["HEALTH_JSON"])
except (json.JSONDecodeError, KeyError) as e:
    print(f"  error: could not parse health response: {e}", file=sys.stderr)
    sys.exit(1)

vpn      = data.get("vpn", {})
services = data.get("services", {})
passed   = data.get("checks_passed", 0)
total    = data.get("checks_total", 0)

GREEN  = "\033[0;32m"
RED    = "\033[0;31m"
YELLOW = "\033[0;33m"
BOLD   = "\033[1m"
NC     = "\033[0m"
CHECK  = GREEN  + "✓" + NC
CROSS  = RED    + "✗" + NC

def ok(msg):  print(f"  {CHECK} {msg}")
def bad(msg): print(f"  {CROSS} {msg}")

# VPN checks
vpn_ip      = vpn.get("ip", "")
vpn_country = vpn.get("country", "")
vpn_port    = vpn.get("port", 0)

if vpn.get("status") == "healthy" and vpn_ip:
    label = f"{vpn_ip} ({vpn_country})" if vpn_country else vpn_ip
    ok(f"VPN tunnel: {label}")
else:
    bad("VPN tunnel: not connected")

if vpn_ip:
    ok(f"VPN IP: {vpn_ip}")
else:
    bad("VPN IP: not available")

if vpn_port and vpn_port > 0:
    ok(f"Port forwarding: port {vpn_port}")
else:
    bad("Port forwarding: not active")

# Service checks
print()
for name, status in sorted(services.items()):
    label = name.capitalize()
    if status == "up":
        ok(f"{label}: reachable")
    else:
        bad(f"{label}: not reachable")

# Summary
print()
if passed == total:
    color = GREEN
elif passed > 0:
    color = YELLOW
else:
    color = RED
print(f"  {color}{BOLD}{passed}/{total} checks passed{NC}")
PYEOF
}

# ── Usage ───────────────────────────────────────────

usage() {
    echo -e "${BOLD}pelicula${NC} — media stack manager"
    echo ""
    echo "Usage: ./pelicula <command> [args]"
    echo ""
    echo "Commands:"
    echo "  setup [--advanced]  First-time setup (generates .env)"
    echo "  configure           Interactive configuration menu"
    echo "  up                  Start all services"
    echo "  down                Stop all services"
    echo "  restart             Stop and restart all services"
    echo "  restart-acquire     Restart acquisition services only (jellyfin/nginx stay up)"
    echo "  status              Show container status"
    echo "  logs [svc]          Tail logs (optionally for one service)"
    echo "  rebuild [svc...]    Rebuild Go services in-place (default: pelicula-api procula)"
    echo "                      Use 'nginx' to reload nginx config/static files"
    echo "  reset-config        Wipe service config (keeps keys/VPN/certs) for a clean re-wire"
    echo "  check-vpn           Verify VPN and service health"
    echo "  update              Pull latest images and recreate containers"
    echo ""
    echo "Services: gluetun, qbittorrent, prowlarr, sonarr, radarr, jellyfin, pelicula-api, procula, nginx"
}

# ── Dispatch ────────────────────────────────────────

case "${1:-}" in
    setup)           cmd_setup "${2:-}" ;;
    configure)       cmd_configure ;;
    up)              cmd_up ;;
    down)            cmd_down ;;
    restart)         cmd_restart ;;
    restart-acquire) cmd_restart_acquire ;;
    rebuild)         cmd_rebuild "${@:2}" ;;
    reset-config)    cmd_reset_config ;;
    status)          cmd_status ;;
    logs)            cmd_logs "${2:-}" ;;
    check-vpn)       cmd_check_vpn ;;
    update)          cmd_update ;;
    -h|--help)       usage ;;
    *)               usage ;;
esac
