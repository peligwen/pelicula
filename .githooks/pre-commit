#!/usr/bin/env bash
# pre-commit: per-module checks on staged Go/shell files.
# Source of truth for module-wide vet/build/test; Claude Code's PostToolUse
# hook runs a faster, package-scoped subset of these checks on each edit.
# Bypass: git commit --no-verify
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
GO_MODULES=("middleware" "procula" "cmd/pelicula")

# Collect staged files (Added, Copied, Modified only — not deletions)
staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [[ -z "$staged_files" ]]; then
  exit 0
fi

# ── Go checks ──────────────────────────────────────────────────────────────────

# Determine which modules have staged .go files (bash 3.2-compatible dedup)
touched_modules=""
while IFS= read -r f; do
  [[ "$f" == *.go ]] || continue
  abs="$REPO_ROOT/$f"
  # Walk up to find go.mod
  d="$(dirname "$abs")"
  while [[ "$d" != "$REPO_ROOT" && "$d" != "/" ]]; do
    if [[ -f "$d/go.mod" ]]; then
      # Store the module path relative to repo root
      rel="${d#"$REPO_ROOT"/}"
      # Dedup: only add if not already present
      case " $touched_modules " in
        *" $rel "*) ;;
        *) touched_modules="$touched_modules $rel" ;;
      esac
      break
    fi
    d="$(dirname "$d")"
  done
done <<< "$staged_files"

if [[ -n "$touched_modules" ]]; then
  for mod in $touched_modules; do
    echo "pre-commit: checking $mod (gofmt + vet + build + test -short)..."
    (
      cd "$REPO_ROOT/$mod"
      unformatted=$(gofmt -l .)
      if [[ -n "$unformatted" ]]; then
        echo "pre-commit: gofmt needs to run on:" >&2
        echo "$unformatted" >&2
        exit 1
      fi
      go vet ./... && go build ./... && go test -short ./...
    )
  done
fi

# ── Shell checks ───────────────────────────────────────────────────────────────

if ! command -v shellcheck &>/dev/null; then
  echo "pre-commit: shellcheck not installed, skipping shell checks" >&2
else
  shell_files=()
  while IFS= read -r f; do
    case "$f" in
      *.sh|pelicula) shell_files+=("$REPO_ROOT/$f") ;;
    esac
  done <<< "$staged_files"

  if [[ ${#shell_files[@]} -gt 0 ]]; then
    echo "pre-commit: shellcheck ${shell_files[*]##"$REPO_ROOT"/}..."
    shellcheck -S warning "${shell_files[@]}"
  fi
fi

echo "pre-commit: ok"
