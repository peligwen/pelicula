# Pelicula stack environment
# ──────────────────────────────────────────────────────────────────────────────
# Generated by `pelicula up` on first run.
#
# EDIT the user-config vars (paths, platform IDs, VPN key).
# Everything marked "(generated by pelicula setup)" is written automatically
# by the setup wizard — leave those blank here; the wizard fills them in.
#
# Optional vars are commented out. Uncomment and set them to override defaults.
# ──────────────────────────────────────────────────────────────────────────────

# ── Platform paths ─────────────────────────────────────────────────────────────
# CONFIG_DIR    — service config files, certs, and runtime state. Keep this on
#                 fast local storage (not a NAS drive). Synology: a shared
#                 folder path under /volume1/ works well.
# LIBRARY_DIR   — media files: movies/, tv/, etc. Can be a NAS mount.
# WORK_DIR      — downloads/ and processing/. Must be writable by the stack;
#                 prefer fast local storage so transcoding isn't bottlenecked.
CONFIG_DIR=./config
LIBRARY_DIR=~/media
WORK_DIR=~/media

# ── User IDs (host UID/GID for bind-mounted permissions) ──────────────────────
# Run `id` in a terminal to find your UID and GID.
# Synology DSM default: PUID=1026, PGID=100
PUID=1000
PGID=1000
TZ=America/New_York

# ── ProtonVPN / Wireguard ──────────────────────────────────────────────────────
# Requires ProtonVPN Plus or higher (free tier lacks P2P + port forwarding).
# Generate from: Settings → Downloads → WireGuard configuration.
# Do NOT enable "Moderate NAT" — it breaks port forwarding.
# Leave blank to start without VPN (download services will be skipped).
WIREGUARD_PRIVATE_KEY=
SERVER_COUNTRIES=Netherlands

# ── Dashboard / nginx ─────────────────────────────────────────────────────────
# PELICULA_PORT — host port nginx binds to. Default 7354 (PELI on a keypad).
# PELICULA_PROJECT_NAME — Docker Compose project name; affects container naming.
#   Change only if running multiple stacks on the same host.
# PELICULA_OPEN_REGISTRATION — "true" allows new users to self-register without
#   an invite link. "false" requires invites (default after first admin registers).
PELICULA_PORT=7354
# PELICULA_PROJECT_NAME=pelicula
# PELICULA_OPEN_REGISTRATION=false

# ── Jellyfin ──────────────────────────────────────────────────────────────────
# (generated by pelicula setup — do not edit manually)
JELLYFIN_ADMIN_USER=admin
JELLYFIN_PASSWORD=
JELLYFIN_API_KEY=

# JELLYFIN_PUBLISHED_URL — LAN URL written into Jellyfin's network.xml so
#   native apps (Apple TV, Roku, Android) can discover the server. Set by the
#   Settings page when you save the LAN URL. Example: http://192.168.1.10:7354/jellyfin
# JELLYFIN_PUBLISHED_URL=

# ── Procula (media processing pipeline) ───────────────────────────────────────
# (generated by pelicula setup — do not edit manually)
PROCULA_API_KEY=

# WEBHOOK_SECRET — HMAC secret shared between pelicula-api and procula for
#   signed webhook payloads. Generated on first `pelicula up`; rotation
#   requires restarting both services.
# (generated by pelicula setup — do not edit manually)
WEBHOOK_SECRET=

# ── Language preferences ───────────────────────────────────────────────────────
# PELICULA_SUB_LANGS — comma-separated ISO 639-1 codes for subtitle acquisition.
#   Example: "en,fr" fetches English then French subtitles.
# PELICULA_AUDIO_LANG — preferred audio language (ISO 639-2/B, 3-letter code).
#   Used by procula when selecting audio streams during transcoding.
# BAZARR_URL — override if bazarr is on a non-default port or path.
# PELICULA_SUB_LANGS=en
# PELICULA_AUDIO_LANG=eng
# BAZARR_URL=http://bazarr:6767/bazarr

# ── Gluetun control API ────────────────────────────────────────────────────────
# HTTP Basic Auth for gluetun's control server (VPN status, speed diagnostics).
# (generated by pelicula setup — do not edit manually)
GLUETUN_HTTP_USER=pelicula
GLUETUN_HTTP_PASS=
# GLUETUN_PROXY_URL=http://gluetun:8888

# ── Feature toggles ────────────────────────────────────────────────────────────
# TRANSCODING_ENABLED — enable procula's post-import transcoding pipeline.
# NOTIFICATIONS_ENABLED / NOTIFICATIONS_MODE — push notification support.
#   NOTIFICATIONS_MODE values: "internal" (SSE only) | "apprise" (external,
#   requires the Apprise compose profile: `docker compose --profile apprise up`).
TRANSCODING_ENABLED=false
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_MODE=internal

# ── Search & requests ─────────────────────────────────────────────────────────
# SEARCH_MODE — "unified" (default) sends requests to both Sonarr and Radarr.
#   Set by the Settings page; usually left as-is.
# REQUESTS_RADARR_PROFILE_ID / REQUESTS_RADARR_ROOT — Radarr quality profile ID
#   and root folder path used when adding a movie via the request flow.
# REQUESTS_SONARR_PROFILE_ID / REQUESTS_SONARR_ROOT — same for Sonarr.
#   These are set automatically by the Settings page after auto-wiring completes.
# SEARCH_MODE=unified
# REQUESTS_RADARR_PROFILE_ID=
# REQUESTS_RADARR_ROOT=
# REQUESTS_SONARR_PROFILE_ID=
# REQUESTS_SONARR_ROOT=

# ── Download behaviour ─────────────────────────────────────────────────────────
# SEEDING_REMOVE_ON_COMPLETE — "true" removes the torrent (and files) from
#   qBittorrent once Sonarr/Radarr mark it as imported.
# SEEDING_REMOVE_ON_COMPLETE=false

# ── Remote access (optional — pick at most one method) ────────────────────────
# REMOTE_MODE values:
#   "disabled"    — no remote vhost (default)
#   "portforward" — self-hosted: opens HTTPS port on your router
#   "cloudflared" — Cloudflare Tunnel (no open ports required)
#   "tailscale"   — Tailscale VPN (no open ports required)
#
# REMOTE_HOSTNAME — public hostname for portforward mode (e.g. jellyfin.example.com).
#   Leave blank to use a self-signed cert on the LAN IP (simple mode).
# REMOTE_HTTP_PORT  — port for HTTP→HTTPS redirect + ACME challenges (portforward mode).
# REMOTE_HTTPS_PORT — port nginx listens on for HTTPS in portforward mode.
# REMOTE_CERT_MODE  — "self-signed" | "byo" | "letsencrypt"
# REMOTE_LE_EMAIL   — required when REMOTE_CERT_MODE=letsencrypt
# REMOTE_LE_STAGING — "true" to use Let's Encrypt staging CA (avoids rate limits
#   during testing). Set to "false" for production.
REMOTE_MODE=disabled
# REMOTE_HOSTNAME=
# REMOTE_HTTP_PORT=80
# REMOTE_HTTPS_PORT=8920
# REMOTE_CERT_MODE=self-signed
# REMOTE_LE_EMAIL=
# REMOTE_LE_STAGING=false

# ── Cloudflare Tunnel (REMOTE_MODE=cloudflared) ───────────────────────────────
# Token from: Cloudflare Zero Trust → Tunnels → Create tunnel → Docker.
# CLOUDFLARE_TUNNEL_TOKEN=

# ── Tailscale (REMOTE_MODE=tailscale) ─────────────────────────────────────────
# TAILSCALE_AUTH_KEY  — ephemeral auth key from tailscale.com/admin/settings/keys
# TAILSCALE_HOSTNAME  — machine name visible in your tailnet (default: pelicula)
# TAILSCALE_AUTH_KEY=
# TAILSCALE_HOSTNAME=pelicula
