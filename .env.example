# ── Platform paths (set by ./pelicula setup) ────
CONFIG_DIR=./config
LIBRARY_DIR=~/media      # where movies/ and tv/ live (can be a NAS mount)
WORK_DIR=~/media         # where downloads/ and processing/ live (local to this stack)

# ── User IDs ────────────────────────────────────
PUID=1026
PGID=100
TZ=America/New_York

# ── ProtonVPN Wireguard ─────────────────────────
WIREGUARD_PRIVATE_KEY=your_private_key_here

# ── Server Selection ────────────────────────────
SERVER_COUNTRIES=Netherlands

# ── Dashboard ───────────────────────────────────
# PELICULA_PORT=7354
